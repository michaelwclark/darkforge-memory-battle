# Copy to `.env` (gitignored) and fill in the keys you actually need.
# You do NOT need all three — only the ones matching the judge providers you
# want to run. See config/judge*.yaml for which provider each config uses.

# OpenRouter — primary path for battle-eligible runs.
# Get one at https://openrouter.ai/keys.
# Required by: config/judge.battle.yaml (claude-sonnet-4-6 via OpenRouter),
#              config/judge.ablation-claude-answer.yaml,
#              config/judge.ablation-claude-scorer.yaml.
# Approximate spend per full 2x2 run (4 contestants * 3 runs, n=20): ~$3-5.
OPENROUTER_API_KEY=

# Anthropic API direct. Optional fallback for battle-eligible runs if you'd
# rather bill Anthropic directly than route through OpenRouter.
# Get one at https://console.anthropic.com/settings/keys.
# Required by: config/judge.yaml entries with provider=anthropic.
ANTHROPIC_API_KEY=

# OpenAI API. Only required for:
#   - validation-only runs with gpt-4o-mini as judge
#   - Hindsight's internal LLM (the Docker container picks this up directly
#     as HINDSIGHT_API_LLM_API_KEY)
#   - Mem0's internal LLM + embedder (its default configuration)
# Get one at https://platform.openai.com/api-keys.
OPENAI_API_KEY=

# Ollama. Only needed if your Ollama isn't at the default http://localhost:11434.
# OLLAMA_HOST=http://localhost:11434
